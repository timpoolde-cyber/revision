  "revision_proposal": {
    "strategy": "Radikale Reduktion nach HfG-Ulm-Prinzip",
    "principles": [
      "Eliminierung jeglichen Codes ohne direkten Conversion-Nutzen",
      "Static-First-Delivery (kompilierte HTML statt Runtime-Rendering)",
      "Conversion-fokussierte Performance als vertriebskritischer KPI"
