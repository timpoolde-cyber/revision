    "recommended_interventions": [
      {
        "intervention": "Code-Splitting & Lazy-Loading",
        "target_metric": "Main-Bundle auf <200 KB reduzieren",
        "expected_impact": "LCP -40%, TTI -50%"
      },
      {
        "intervention": "DOM-Tree-Rationalisierung",
        "target_metric": "DOM-Tiefe auf <100, DOM-Knoten auf <500",
        "expected_impact": "CLS <0.1, Rendering-Performance +60%"
      },
      {
        "intervention": "Third-Party-Isolation",
        "target_metric": "Externe Scripts in Web-Worker oder Sandbox auslagern",
        "expected_impact": "Main-Thread-Blockade -70%"
      },
      {
        "intervention": "Static-HTML-First-Architektur",
        "target_metric": "Server-seitige Pre-Rendering statt Client-Side-Rendering",
        "expected_impact": "FCP -50%, Conversion-Rate +15-25%"
      }
    ],
    "timeline": "6-8 Wochen für Enterprise-Grade-Implementierung"
