RewriteEngine On

# 1. kurz-url für vip-karten
RewriteRule ^vip$ /flow/vip/ [L,QSA,R=301]

# 2. vorausschauend: kurz-url für maps/postkarten
RewriteRule ^maps$ /flow/maps/ [L,QSA,R=301]

# 3. vorausschauend: kurz-url für allgemeine leads
RewriteRule ^lead$ /flow/lead/ [L,QSA,R=301]

# SECURITY: Block access to sensitive files and directories
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

<FilesMatch "\.(env|db|sqlite|sqlite3|log|md|ini)$">
    Require all denied
</FilesMatch>

Options -Indexes

<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "DENY"
    Header set X-XSS-Protection "1; mode=block"
</IfModule>
